# ============================================================
# iPhone在庫マトリックス - 環境変数
# このファイルを .env.local にコピーして値を設定してください
# ============================================================

# Supabase設定（必須）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key（管理APIで使用）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron認証（必須）
# openssl rand -hex 32 で生成してください
CRON_SECRET=your-cron-secret-here

# LINE Messaging API設定（個別通知に必要）
# LINE Developersコンソールで取得してください
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# 通知API認証（ワーカーからのリクエスト認証用）
# openssl rand -hex 32 で生成してください
NOTIFY_API_SECRET=your-notify-api-secret
